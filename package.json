{
  "name": "masky-js",
  "version": "1.0.4",
  "description": " Tiny, zero-dependency JavaScript input mask — declarative via HTML data-attributes, no build or framework needed. Custom masks, prefixes, suffixes, reverse/currency masks, and built-in CPF/CNPJ validation.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eduardovillao/masky-js.git"
  },
  "main": "dist/masky.min.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "terser src/masky.js --compress --mangle --toplevel --ecma 2020 -o dist/masky.min.js"
  },
  "keywords": [
    "javascript",
    "vanilla-js",
    "input-mask",
    "inputmask",
    "text-mask",
    "mask",
    "masking",
    "currency-mask",
    "phone-mask",
    "cpf",
    "cnpj",
    "cpf-validation",
    "cnpj-validation",
    "zero-dependency",
    "form-validation",
    "astro"
  ],
  "author": "EduardoVillao",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eduardovillao/masky-js/issues"
  },
  "homepage": "https://github.com/eduardovillao/masky-js",
  "devDependencies": {
    "jsdom": "^27.4.0",
    "terser": "^5.48.0",
    "vitest": "^4.0.18"
  }
}
