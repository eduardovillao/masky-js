{
  "name": "masky-js",
  "version": "1.0.3",
  "description": "A lightweight and flexible JavaScript library for input masking. Supports custom masks, prefixes, suffixes, and built-in CPF/CNPJ validation for forms.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eduardovillao/masky-js.git"
  },
  "main": "dist/masky.min.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "terser src/masky.js --compress --mangle --toplevel --ecma 2020 -o dist/masky.min.js"
  },
  "keywords": [
    "JavaScript",
    "form-validation",
    "input-mask",
    "mask",
    "masking",
    "cpf",
    "cnpj"
  ],
  "author": "EduardoVillao",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eduardovillao/masky-js/issues"
  },
  "homepage": "https://github.com/eduardovillao/masky-js",
  "devDependencies": {
    "jsdom": "^27.4.0",
    "terser": "^5.48.0",
    "vitest": "^4.0.18"
  }
}
